{
	"name": "text-count",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"lint": "eslint .",
		"dev:api": "npm -w api run serve",
		"dev:web": "npm -w web run dev",
		"build:api": "npm -w api run build",
		"build:web": "npm -w web run build",
		"test:api": "npm -w api run test",
		"test:web": "npm -w web run test",
		"test": "npm run test:web && npm run test:api"
	},
	"dependencies": {
		"firebase": "^11.8.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.27.0",
		"eslint": "^9.27.0",
		"eslint-plugin-import": "^2.25.4",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"globals": "^15.15.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.33.0"
	}
}